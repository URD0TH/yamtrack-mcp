{
  "name": "@urd0th/yamtrack-mcp",
  "version": "0.1.0",
  "description": "MCP server (stdio or http) that exposes Yamtrack's REST API as tools for LLMs",
  "license": "AGPL-3.0",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "yamtrack",
    "media-tracker",
    "llm",
    "ai"
  ],
  "homepage": "https://github.com/URD0TH/yamtrack-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/URD0TH/yamtrack-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/URD0TH/yamtrack-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "yamtrack-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "serve": "node dist/index.js serve",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.build.json && node dist/index.js",
    "typecheck": "tsc",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "pm2": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}

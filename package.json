{
  "name": "yamtrack-mcp",
  "version": "0.1.0",
  "description": "MCP server (stdio or http) that exposes Yamtrack's REST API as tools for LLMs",
  "license": "AGPL-3.0",
  "keywords": ["mcp", "modelcontextprotocol", "yamtrack", "media-tracker", "llm", "ai"],
  "homepage": "https://github.com/URD0TH/yamtrack-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/URD0TH/yamtrack-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/URD0TH/yamtrack-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "yamtrack-mcp": "dist/index.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.build.json && node dist/index.js",
    "typecheck": "tsc",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
